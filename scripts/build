#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/boltz-bio/boltz-api-go,github.com/stainless-sdks/boltz-compute-api-go"

echo "==> Building boltz-api"
go build ./cmd/boltz-api
